# Copy to `.env` (git-ignored) and fill in. Consumed by docker-compose.yml.
# These credentials are for the LOCAL research stack only.

# --- PostgreSQL (MLflow backend store + experiment/run/trade registry) ---
POSTGRES_USER=qrp
POSTGRES_PASSWORD=change_me
POSTGRES_DB=qrp_registry
POSTGRES_PORT=5432

# --- MLflow tracking server ---
MLFLOW_PORT=5000
# Artifact store is a named docker volume by default (see docker-compose.yml).
